#!/bin/bash
FILTERSTR='\.[df]\.\.t\.\.\.\.\.\.'
BACKUPDIR="$HOME/.Trash-rsync/$(date +%Y%m%d)"
if [[ -d /run/media/jdyer ]]; then
    BASE="/run/media/jdyer"
elif [[ -d /media/jdyer ]]; then
    BASE="/media/jdyer"
else
    BASE="/media/jdyer"
fi
# Include/exclude lists are the shared single source of truth in the bootstrap
# repo (also drives refresh-usb.sh and sync-from-nas.sh). See lib/payload.sh.
INC_FILE="$HOME/bin/bootstrap/lib/home-include.txt"
EXC_FILE="$HOME/bin/bootstrap/lib/home-exclude.txt"
# rsync --include patterns for paths that are git-ignored (by nested .gitignore)
# but should still be backed up. Inserted before --exclude-from=GIT_EXCLUDE_FILE
# so rsync's "first match wins" semantics include them before the git-ignore
# exclusions. Patterns anchored to transfer root (leading '/').
GIT_INCLUDE_OVERRIDES=(
    '/.emacs.d/offline-packages/local-packages/**'
)

# Remove any temp git-ignore exclude file on exit/abort. Guarded so an early
# exit before cleanup_git_excludes() is defined doesn't error.
trap 'command -v cleanup_git_excludes >/dev/null 2>&1 && cleanup_git_excludes' EXIT INT TERM

function list_filters ()
{
    echo "dryrun   : $DRY"
    echo "included : $INC"
    echo "trash    : $TRASH"
    echo "sanity   : $SANITY"
    echo "excluded : $EXCL"
}

function select_dir ()
{
    select DIR in "$BASE"/*;
    do
        break
    done
}

function tidy_up() {
    local IFS=,
    TYPES="webp,jpg,jpeg,png"
    VIDEO_TYPES="mp4,mov,avi,mkv,webm,m4v"
    DIRS="DCIM/Camera,DCIM/Screenshots,Snapseed"
    VIDEO_DIRS="DCIM/Camera"
    image_log_file="$HOME/DCIM/processed_files_with_checksum.log"
    video_log_file="$HOME/DCIM/processed_videos_with_checksum.log"
    
    # Number of parallel processes
    PARALLEL_JOBS=$(nproc)
    
    touch "$image_log_file"
    touch "$video_log_file"
    
    # Function to process a single image file
    process_single_file() {
        local A="$1"
        local DIR="$2"
        local log_file="$3"
        
        source Common.sh
        
        pre
        
        # Skip if already processed (persistent xattr marker survives content changes)
        if getfattr -d --absolute-names "$A" 2>/dev/null | grep -q 'user.do_backup.processed'; then
            return 0
        fi
        
        checksum=$(md5sum "$A" | awk '{ print $1 }')
        
        # Simple check (note: this has potential race conditions)
        if grep -q "$checksum" "$log_file"; then
            return 0
        fi
        
        EXT=jpg
        get_trunc_name
        exiftool -orientation#=1 -overwrite_original_in_place "-FileModifyDate<DateTimeOriginal" "-FileModifyDate<CreateDate" "$A"
        
        if [[ "$A" =~ IMG-[0-9]{8}-WA[0-9]{4}\.jpg$ ]]; then
            echo "Skipping rotation for WhatsApp image: $A"
            convert_it "$A" -auto-orient -strip -quality 50% "$TRUNCNAME"
        else
            if [[ "$DIR" == "DCIM/Camera" ]]; then
                echo "Rotating image: $A (Camera directory)"
                convert_it "$A" -auto-orient -rotate 90 -strip -quality 50% "$TRUNCNAME"
            else
                echo "Skipping rotation for image: $A (non-Camera directory)"
                convert_it "$A" -auto-orient -strip -quality 50% "$TRUNCNAME"
            fi
        fi
        
        # Mark as processed with persistent xattr (survives checksum changes from later edits)
        setfattr -n user.do_backup.processed -v 1 "$TRUNCNAME" 2>/dev/null
        
        checksum=$(md5sum "$TRUNCNAME" | awk '{ print $1 }')
        echo "$checksum $TRUNCNAME" >> "$log_file"
    }
    
    # Function to process a single video file
    process_single_video() {
        local A="$1"
        local log_file="$2"
        
        source Common.sh
        
        pre
        
        # Calculate checksum of original file
        checksum=$(md5sum "$A" | awk '{ print $1 }')
        
        # Check if already processed with this checksum
        if grep -q "^$checksum " "$log_file"; then
            return 0
        fi
        
        EXT=mp4
        NEWFILE="${BASEDIR}/${FILE_NO_EXT}.${EXT}"
        
        # Get current video dimensions
        CURRENT_RES=$(ffprobe -v error -select_streams v:0 -show_entries stream=width,height -of csv=s=x:p=0 "$A" 2>/dev/null)
        
        if [ -z "$CURRENT_RES" ]; then
            echo "Error: Could not read video dimensions for $A"
            return 1
        fi
        
        CURRENT_WIDTH=$(echo "$CURRENT_RES" | cut -d'x' -f1)
        CURRENT_HEIGHT=$(echo "$CURRENT_RES" | cut -d'x' -f2)
        
        echo "[$A] Current resolution: ${CURRENT_WIDTH}x${CURRENT_HEIGHT}"
        
        # Check if video needs resizing (if either dimension exceeds 960x960)
        if [ "$CURRENT_WIDTH" -le 960 ] && [ "$CURRENT_HEIGHT" -le 960 ]; then
            echo "Video already within target size, skipping: $A"
            checksum=$(md5sum "$A" | awk '{ print $1 }')
            echo "$checksum $A" >> "$log_file"
            return 0
        fi
        
        # Calculate scaling to fit within 960x960 while maintaining aspect ratio
        SCALE_FILTER="scale='min(960,iw)':'min(960,ih)':force_original_aspect_ratio=decrease"
        
        echo "Processing video: $A -> $NEWFILE"
        
        # Process video and replace original
        convert_it_video "$A" \
               -vf "$SCALE_FILTER" \
               -vcodec libx264 \
               -crf 28 \
               -preset medium \
               -movflags +faststart \
               "$NEWFILE"
        
        if [ $? -eq 0 ]; then
            # Calculate new checksum
            new_checksum=$(md5sum "$NEWFILE" | awk '{ print $1 }')
            
            # Log the new checksum
            echo "$new_checksum $NEWFILE" >> "$log_file"
            echo "Successfully processed and replaced: $NEWFILE"
        else
            echo "Error processing video: $A"
            return 1
        fi
    }
    
    export -f process_single_file
    export -f process_single_video
    
    # Process images
    echo "=========================================="
    echo "Processing Images..."
    echo "=========================================="
    for DIR in $DIRS; do
        [[ -d "$HOME/$DIR" ]] || { echo "skip (not found): $DIR"; continue; }
        cd "$HOME/$DIR" || continue
        echo
        echo "**************** Checking $DIR for images"
        echo
        for TYPE in $TYPES; do
            echo "Processing $TYPE files in $DIR..."
            
            find "$HOME/$DIR" -iname "*.$TYPE" -print0 | \
                xargs -0 -I {} -P "$PARALLEL_JOBS" -n 1 \
                      bash -c 'process_single_file "$1" "$2" "$3"' _ {} "$DIR" "$image_log_file"
        done
    done
    
    # Process videos
    echo
    echo "=========================================="
    echo "Processing Videos..."
    echo "=========================================="
    for DIR in $VIDEO_DIRS; do
        [[ -d "$HOME/$DIR" ]] || { echo "skip (not found): $DIR"; continue; }
        cd "$HOME/$DIR" || continue
        echo
        echo "**************** Checking $DIR for videos"
        echo
        for TYPE in $VIDEO_TYPES; do
            echo "Processing $TYPE files in $DIR..."
            
            find "$HOME/$DIR" -iname "*.$TYPE" -print0 | \
                xargs -0 -I {} -P "$PARALLEL_JOBS" -n 1 \
                      bash -c 'process_single_video "$1" "$2"' _ {} "$video_log_file"
        done
    done
    
    echo
    echo "=========================================="
    echo "Tidy up complete!"
    echo "=========================================="
}

function do_input ()
{
    echo "SOURCE"
    select_dir
    SRC=$DIR
    echo "DESTINATION"
    select_dir
    DST=$DIR
    echo "======================================================================"
    echo "DOING ${SRC}/ -> ${DST}/"
    list_filters
    echo "======================================================================"
    echo "Continue? (any key)"
    read -re
    do_it
}

# Path to a temp file of git-derived exclude patterns, populated by
# build_gitignore_excludes() for the current do_it() run and removed by
# cleanup_git_excludes() (also wired to EXIT).
GIT_EXCLUDE_FILE=""

function cleanup_git_excludes ()
{
    if [[ -n "$GIT_EXCLUDE_FILE" && -f "$GIT_EXCLUDE_FILE" ]]; then
        rm -f "$GIT_EXCLUDE_FILE"
    fi
    GIT_EXCLUDE_FILE=""
}

# For every git repository found under $1 (bounded depth; heavy junk dirs
# pruned), ask `git ls-files --ignored --exclude-standard` to list the paths
# git would ignore there, then emit them as rsync exclude patterns anchored to
# the transfer root ($1). Honors .gitignore at all levels, .git/info/exclude
# and core.excludesFile, with correct '!' re-include handling. Safe to run on
# non-git trees: it simply produces an empty file.
function build_gitignore_excludes ()
{
    local root="$1"
    cleanup_git_excludes
    [[ -d "$root" ]] || return 0
    command -v git >/dev/null 2>&1 || { echo "git not found; skipping .gitignore filtering"; return 0; }

    local tmp
    tmp=$(mktemp -t do_backup-gitignore.XXXXXX) || return 0

    local gitdir repo entry full rel
    # Prune node_modules/.cache/__pycache__ so the scan stays fast; prune .git
    # dirs themselves so find doesn't recurse into their (large) object store.
    while IFS= read -r -d '' gitdir; do
        repo=$(dirname "$gitdir")
        while IFS= read -r -d '' entry; do
            [[ -z "$entry" ]] && continue
            full="$repo/$entry"
            # Strip "$root/" prefix to make the path relative to SRC. Account
            # for the case where repo == root (no prefix to strip).
            if [[ "$full" == "$root/"* ]]; then
                rel=${full#"$root/"}
            else
                rel=$full
            fi
            # rsync exclude-from entries are patterns; leading '/' anchors to
            # the transfer root. Trailing '/' (dirs from --directory) is kept.
            printf '/%s\n' "$rel"
        done < <(git -C "$repo" ls-files --others --ignored --exclude-standard -z --directory 2>/dev/null)
    done < <(find "$root" -maxdepth 5 \
                \( -name node_modules -o -name .cache -o -name __pycache__ \
                   -o -name offline-packages \) -prune \
                -o -type d -name .git -prune -print0 2>/dev/null) >> "$tmp"

    if [[ -s "$tmp" ]]; then
        GIT_EXCLUDE_FILE="$tmp"
    else
        rm -f "$tmp"
        GIT_EXCLUDE_FILE=""
    fi
}

function do_it ()
{
    # Enumerate git-ignored paths under SRC by asking git itself (full gitignore
    # semantics incl. '!' negations, .git/info/exclude, core.excludesFile) and
    # feed them to rsync as anchored excludes. rsync's own ':-' merge rule is
    # NOT used because it misreads git's '!' (it means "clear filter list" in
    # rsync, not re-include) and would silently wipe exclude-everything style
    # dotfile repos (e.g. ~/.config).
    build_gitignore_excludes "$SRC"

    RSYNC_CMD=(
        rsync -rltsiPv --no-g --copy-links --delete --modify-window=4 --ignore-missing-args
        --filter='P /lost+found'
        --exclude '.Trash*' --exclude '#recycle*' --exclude '_recycle*'
        --exclude-from="$EXC_FILE"
        "${EXTRA_EXCLUDES[@]}"
    )
    # Git-ignore overrides must come BEFORE --exclude-from=GIT_EXCLUDE_FILE
    # so they match first (rsync: first matching rule wins).
    for pat in "${GIT_INCLUDE_OVERRIDES[@]}"; do
        RSYNC_CMD+=("--include=$pat")
    done
    if [[ -n "$GIT_EXCLUDE_FILE" ]]; then
        RSYNC_CMD+=(--exclude-from="$GIT_EXCLUDE_FILE")
    fi
    EXTRA_EXCLUDES=()

    if [[ ! -d "$SRC" ]]; then
        echo
        echo "WARNING! $SRC NOT FOUND"
        echo
        return 1
    fi

    if [[ ! -d "$DST" ]]; then
        echo
        echo "WARNING! $DST NOT FOUND"
        echo
        return 1
    fi

    if [[ $DRY == 1 ]]; then
        RSYNC_CMD+=(--dry-run)
    fi

    if [[ $EXCL == 1 ]]; then
        RSYNC_CMD+=(--delete-excluded)
    fi

    if [[ $INC == 1 ]]; then
        RSYNC_CMD+=(--files-from="${INC_FILE}")
    fi

    if [[ $TRASH == 1 ]]; then
        RSYNC_CMD+=(--backup-dir="${BACKUPDIR}")
    fi

    RSYNC_CMD+=("${SRC}/" "${DST}/")

    list_filters
    echo "${RSYNC_CMD[*]}"
    
    "${RSYNC_CMD[@]}" | stdbuf -oL grep -v "$FILTERSTR"

    if [[ $SANITY == 1 ]]; then
        echo "Sanity Check $SRC -> $DST ...."
        S1=$(mktemp)
        S2=$(mktemp)
        cd "$SRC" || return 1
        ls -R --ignore="OneDrive" --ignore="Maildir" --ignore=".Trash*" --ignore="#recycle" --ignore="_recycle" > "$S1"
        cd "$DST" || return 1
        ls -R --ignore="OneDrive" --ignore="Maildir" --ignore=".Trash*" --ignore="#recycle" --ignore="_recycle" > "$S2"
        diff --side-by-side --suppress-common-lines "$S1" "$S2"
        rm -f "$S1" "$S2"
    fi

    echo
    echo "Finished"
    echo
}

function backup_home ()
{
    DRY=0
    INC=1
    TRASH=0
    SANITY=0
    EXCL=1

    # backup maildir need to tar as handling of colon not great
    DATE=$(date +%Y%m%d)
    MONTH=$(date +%m)
    DAY=$(date +%d)
    MAIL_FILE="$HOME/MAIL"
    cd "$HOME"
    if [[ $DAY = "07" || $DAY = "14" || $DAY = "21" || $DAY = "28" ]]; then
        if [[ ! -f "$MAIL_FILE" ]]; then
            echo
            echo "---------- Doing Maildir ----------"
            echo
            tar zcf Maildir.tar.gz \
                --exclude='Maildir/*/tmp' \
                --exclude='Maildir/*/*/tmp' \
                .thunderbird Maildir
            echo
            echo "---------- Done Maildir ----------"
            echo
            touch "$MAIL_FILE"
        fi
    else
        rm -f "$MAIL_FILE"
    fi

    # backup other things
    ARC_FILE="$HOME/ARCHIVE"
    if [[ $MONTH = "11" ]]; then
        if [[ ! -f "$ARC_FILE" ]]; then
            TARGET="$HOME/nas/Archive/Documents/$DATE"
            mkdir -p "$TARGET"
            rsync -avP --no-g ~/DCIM/content/RedSaucers.kdbx \
                  "$TARGET/$DATE--RedSaucers.kdbx"
            # rsync -avP --no-g ~/DCIM/Volume \
                  # $TARGET/"$DATE"--Volume
            rsync -avP --no-g ~/Maildir.tar.gz \
                  "$TARGET/$DATE--Maildir.tar.gz"
            rsync -avP --no-g ~/DCIM/Backup/Contacts.vcf \
                  "$TARGET/$DATE--Contacts.vcf"
            touch "$ARC_FILE"
        fi
    else
        rm -f "$ARC_FILE"
    fi

    # Main backup
    SRC="$HOME"
    DST="$HOME/nas/Home"
    START_TS=$(date +%s)
    do_it
    ELAPSED=$(( $(date +%s) - START_TS ))
    echo "Backup of home to nas/Home completed in $(date -d@$ELAPSED -u +%H:%M:%S)"
}

SKIP_TIDY=0
ARGS=()
for arg in "$@"; do
    case $arg in
        --skip-tidy) SKIP_TIDY=1 ;;
        *) ARGS+=("$arg") ;;
    esac
done
set -- "${ARGS[@]}"

function do_backup_home ()
{
    if [[ $SKIP_TIDY == 0 ]]; then
        echo "=========================================="
        echo "Pre-processing images and videos..."
        echo "(run 'do_backup --skip-tidy' to skip this)"
        echo "=========================================="
        tidy_up
    else
        echo "Skipping image/video pre-processing."
    fi
    backup_home
}

cd "$HOME/nas" || exit

if [[ $# -gt 0 ]]; then
    if [[ $1 == "home" ]]; then
        do_backup_home
    else
        backup_home
    fi
    exit
fi

select PRESET in home usb-home ventoy disks $BASE/*;
do
    case $PRESET in
        home)
            do_backup_home
            break
            ;;
        usb-home)
            select QUICK in "$BASE"/*;
            do
                DRY=0
                INC=1
                TRASH=0
                SANITY=0
                EXCL=1
                SRC="$HOME"
                DST="$QUICK/Home"
                do_it
                exit
            done
            ;;
        ventoy)
            DRY=0
            INC=1
            TRASH=0
            SANITY=0
            EXCL=1
            EXTRA_EXCLUDES=(
                --exclude 'nas' --exclude 'python3.9' --exclude 'kate'
                --exclude 'plasma' --exclude '.git' --exclude 'Photos'
                --exclude 'Maildir' --exclude '.thunderbird' --exclude 'Volume'
                --exclude 'Videos' --exclude 'KritaRecorder' --exclude 'Reference'
                --exclude 'music'
            )
            SRC="$HOME"
            DST="$BASE/Ventoy/Home"
            do_it
            exit
            ;;
        disks)
            DRY=0
            INC=0
            TRASH=0
            SANITY=1
            EXCL=1
            do_input
            break
            ;;
        *)
            DRY=0
            INC=0
            TRASH=0
            SANITY=1
            EXCL=1
            SRC="$HOME/nas"
            DST="$PRESET"
            if [[ ! -d "$SRC/Home" ]]; then
                echo
                echo "WARNING! $SRC/Home NOT FOUND"
                echo
                exit
            fi
            if [[ ! -d "$DST/Home" ]]; then
                echo
                echo "WARNING! $DST/Home NOT FOUND"
                echo
                exit
            fi
            do_it
            break
            ;;
    esac
done

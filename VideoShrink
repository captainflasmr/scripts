#!/bin/bash
source Common.sh

# Configuration
TARGET_WIDTH=960
TARGET_HEIGHT=960
LOG_FILE="$HOME/DCIM/processed_videos_with_checksum.log"
PARALLEL_JOBS=$(nproc)

# Create log file if it doesn't exist
touch "$LOG_FILE"

function process_video() {
    local A="$1"
    local LOG_FILE="$2"
    
    source Common.sh
    
    pre
    
    # Calculate checksum of original file
    checksum=$(md5sum "$A" | awk '{ print $1 }')
    
    # Check if already processed with this checksum
    if grep -q "^$checksum " "$LOG_FILE"; then
        echo "Skipping already processed: $A"
        return 0
    fi
    
    EXT=mp4
    NEWFILE="${BASEDIR}/${FILE_NO_EXT}.${EXT}"
    
    # Get current video dimensions
    CURRENT_RES=$(ffprobe -v error -select_streams v:0 -show_entries stream=width,height -of csv=s=x:p=0 "$A" 2>/dev/null)
    echo "[$A] Current resolution: $CURRENT_RES"
    
    # Calculate scaling to fit within 960x960 while maintaining aspect ratio
    SCALE_FILTER="scale='min(960,iw)':'min(960,ih)':force_original_aspect_ratio=decrease"
    
    echo "Processing: $A -> $NEWFILE"
    
    # Process video and replace original
    convert_it_video "$A" \
           -vf "$SCALE_FILTER" \
           -vcodec libx264 \
           -crf 28 \
           -preset medium \
           -movflags +faststart \
           "$NEWFILE"
    
    if [ $? -eq 0 ]; then
        # Calculate new checksum
        new_checksum=$(md5sum "$NEWFILE" | awk '{ print $1 }')
        
        # Remove old checksum entry if it exists
        grep -v "^$checksum " "$LOG_FILE" > "$LOG_FILE.tmp"
        mv "$LOG_FILE.tmp" "$LOG_FILE"
        
        # Log the new checksum
        echo "$new_checksum $NEWFILE" >> "$LOG_FILE"
        echo "Successfully processed and replaced: $NEWFILE"
    else
        echo "Error processing: $A"
        return 1
    fi
}

export -f process_video

# Find and process videos in parallel
VIDEO_TYPES="mp4,mov,avi,mkv,webm,m4v"
IFS=,

for TYPE in $VIDEO_TYPES; do
    echo "Processing $TYPE files..."
    
    find . -iname "*.$TYPE" -print0 | \
        xargs -0 -I {} -P "$PARALLEL_JOBS" -n 1 \
              bash -c 'process_video "$1" "$2"' _ {} "$LOG_FILE"
done

echo "Video processing complete!"
